[Unit]
Description=Activity Browser Web Server
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/mango/workspace/activity-suggester/server/activity-server.py --port 8092
WorkingDirectory=/home/mango/workspace/activity-suggester/server
Restart=always
RestartSec=3
Environment=PYTHONUNBUFFERED=1
Environment=HOMEASSISTANT_URL=http://192.168.50.84:8123
EnvironmentFile=/home/mango/.hermes/secrets/ha-env

[Install]
WantedBy=default.target
